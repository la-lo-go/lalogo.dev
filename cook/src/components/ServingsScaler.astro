---
// Selector de raciones que multiplica las cantidades de la sección
// "Ingredientes". La base son las raciones de la propiedad de Notion.
export interface Props {
  baseServings: number;
}
const { baseServings } = Astro.props;
---

<div
  class="servings-scaler border-2 border-secondary p-3 mt-6 flex items-center gap-3 flex-wrap"
  data-base={baseServings}
  hidden
>
  <span class="font-bold">Raciones</span>

  <div class="flex items-center gap-2">
    <button
      type="button"
      class="servings-step cursor-pointer w-8 h-8 border-2 border-secondary font-bold text-xl leading-none transition-colors hover:bg-secondary hover:text-white disabled:opacity-30 disabled:cursor-not-allowed"
      data-step="-1"
      aria-label="Menos raciones"
    >
      −
    </button>
    <output class="servings-value min-w-8 text-center text-lg font-bold tabular-nums"
      >{baseServings}</output
    >
    <button
      type="button"
      class="servings-step cursor-pointer w-8 h-8 border-2 border-secondary font-bold text-xl leading-none transition-colors hover:bg-secondary hover:text-white"
      data-step="1"
      aria-label="Más raciones"
    >
      +
    </button>
  </div>

  <button
    type="button"
    class="servings-reset cool-link cursor-pointer text-sm"
    hidden
    aria-label="Restablecer raciones"
  >
    restablecer
  </button>
</div>

<script>
  import { scaleIngredientText } from "@lib/scaleIngredients";
  import { ensureIngredientsProcessed } from "@lib/recipeDom";

  function setupServingsScaler() {
    const scaler = document.querySelector<HTMLElement>(".servings-scaler");
    if (!scaler || scaler.dataset.bound === "1") return;

    const base = Number(scaler.dataset.base);
    const items = ensureIngredientsProcessed();
    const texts = items
      .map((li) => li.querySelector<HTMLElement>(".ing-text"))
      .filter((el): el is HTMLElement => el !== null);

    // Sin raciones válidas o sin ingredientes detectados: no mostramos nada.
    if (!base || base <= 0 || texts.length === 0) {
      scaler.hidden = true;
      return;
    }
    scaler.dataset.bound = "1";

    const valueEl = scaler.querySelector<HTMLOutputElement>(".servings-value")!;
    const resetEl = scaler.querySelector<HTMLButtonElement>(".servings-reset")!;
    const minusEl = scaler.querySelector<HTMLButtonElement>('[data-step="-1"]')!;
    let current = base;

    const render = () => {
      const factor = current / base;
      for (const span of texts) {
        span.textContent = scaleIngredientText(span.dataset.original ?? "", factor);
      }
      valueEl.textContent = String(current);
      resetEl.hidden = current === base;
      minusEl.disabled = current <= 1;
    };

    for (const btn of scaler.querySelectorAll<HTMLButtonElement>(".servings-step")) {
      btn.addEventListener("click", () => {
        current = Math.max(1, current + Number(btn.dataset.step));
        render();
      });
    }
    resetEl.addEventListener("click", () => {
      current = base;
      render();
    });

    render();
    scaler.hidden = false;
  }

  if (document.readyState !== "loading") setupServingsScaler();
  else document.addEventListener("DOMContentLoaded", setupServingsScaler);
  document.addEventListener("astro:page-load", setupServingsScaler);
</script>
