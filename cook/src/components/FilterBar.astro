---
import { NormalizeText } from "@lib/Text";

export interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="mt-4 space-y-3">
  <label class="sr-only" for="recipe-search">Buscar receta</label>
  <input
    id="recipe-search"
    type="search"
    placeholder="Buscar receta..."
    autocomplete="off"
    class="w-full sm:max-w-xs bg-transparent border-0 border-b-2 border-secondary placeholder:text-secondary/50 px-1 py-1.5 focus:outline-none focus:bg-gray/50"
  />

  {
    tags.length > 0 && (
      <ul id="tag-filters" class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <li>
            <button
              type="button"
              data-tag={NormalizeText(tag)}
              aria-pressed="false"
              class="tag-toggle border-2 border-secondary px-2 py-0.5 text-sm font-medium transition-colors hover:bg-gray"
            >
              {tag}
            </button>
          </li>
        ))}
      </ul>
    )
  }
</div>

<script>
  function normalize(text: string): string {
    return text
      .toLowerCase()
      .normalize("NFD")
      .replace(/\p{Diacritic}/gu, "");
  }

  function setupFilters() {
    const search = document.getElementById(
      "recipe-search"
    ) as HTMLInputElement | null;
    const grid = document.getElementById("recipe-grid");
    // The bound flag prevents double listeners when both the immediate call
    // and astro:page-load run on the same DOM (a double toggle would no-op).
    if (!search || !grid || search.dataset.bound === "1") return;
    search.dataset.bound = "1";

    const cards = Array.from(grid.querySelectorAll<HTMLElement>("[data-search]"));
    const toggles = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".tag-toggle")
    );
    const noResults = document.getElementById("no-results");
    const activeTags = new Set<string>();

    const apply = () => {
      const query = normalize(search.value.trim());
      let visible = 0;

      for (const card of cards) {
        const matchesText =
          query === "" || (card.dataset.search ?? "").includes(query);
        const cardTags = new Set((card.dataset.tags ?? "").split("|"));
        const matchesTags = [...activeTags].every((tag) => cardTags.has(tag));
        const show = matchesText && matchesTags;

        card.classList.toggle("hidden", !show);
        if (show) visible++;
      }

      noResults?.classList.toggle("hidden", visible > 0);
    };

    search.addEventListener("input", apply);

    for (const toggle of toggles) {
      toggle.addEventListener("click", () => {
        const tag = toggle.dataset.tag ?? "";
        let isActive: boolean;

        if (activeTags.has(tag)) {
          activeTags.delete(tag);
          isActive = false;
        } else {
          activeTags.add(tag);
          isActive = true;
        }

        toggle.classList.toggle("bg-secondary", isActive);
        toggle.classList.toggle("text-primary", isActive);
        toggle.setAttribute("aria-pressed", String(isActive));
        apply();
      });
    }
  }

  setupFilters();
  document.addEventListener("astro:page-load", setupFilters);
</script>
