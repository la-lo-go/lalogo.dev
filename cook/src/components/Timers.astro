---
// Temporizadores en-página: un botón flotante abre un panel donde crear
// varios temporizadores. Al terminar suenan, vibran (Android) y avisan
// visualmente. No hay API web para crear timers nativos del sistema, así que
// esto funciona dentro del navegador en Android e iOS.
import { Icon } from "astro-icon/components";
---

<div class="timers-root">
  <button
    type="button"
    class="timers-fab fixed bottom-5 right-5 z-[60] w-14 h-14 rounded-full bg-secondary text-white text-2xl shadow-lg cursor-pointer flex items-center justify-center"
    aria-label="Temporizadores"
  >
    <Icon name="lucide:timer" class="w-6 h-6" />
    <span class="timers-badge hidden absolute -top-1 -right-1 min-w-5 h-5 px-1 rounded-full bg-white text-secondary text-xs font-bold border-2 border-secondary items-center justify-center"></span>
  </button>

  <div
    class="timers-panel fixed bottom-24 right-5 z-[60] w-72 max-w-[calc(100vw-2.5rem)] bg-white border-2 border-secondary p-3"
    hidden
  >
    <div class="flex items-center justify-between mb-2">
      <span class="font-bold">Temporizadores</span>
      <button type="button" class="timers-close cursor-pointer leading-none" aria-label="Cerrar"><Icon name="lucide:x" class="w-5 h-5" /></button>
    </div>

    <ul class="timers-list space-y-2 mb-3 max-h-64 overflow-y-auto"></ul>
    <p class="timers-empty text-sm italic text-secondary/60 mb-3">No hay temporizadores.</p>

    <div class="flex gap-1.5 mb-2">
      <button type="button" class="timers-add-min cursor-pointer flex-1 border-2 border-secondary py-1 text-sm font-medium transition-colors hover:bg-secondary hover:text-white" data-min="1">+1 min</button>
      <button type="button" class="timers-add-min cursor-pointer flex-1 border-2 border-secondary py-1 text-sm font-medium transition-colors hover:bg-secondary hover:text-white" data-min="10">+10 min</button>
      <button type="button" class="timers-add-min cursor-pointer flex-1 border-2 border-secondary py-1 text-sm font-medium transition-colors hover:bg-secondary hover:text-white" data-min="30">+½ h</button>
    </div>

    <div class="timers-pending hidden items-center justify-between gap-2 mb-2 border-2 border-secondary bg-gray px-2 py-1">
      <span class="text-sm font-bold">Nuevo: <span class="timers-pending-time tabular-nums">00:00</span></span>
      <button type="button" class="timers-pending-start cursor-pointer border-2 border-secondary bg-secondary text-white px-2 py-0.5 text-sm font-bold">Iniciar</button>
    </div>

    <form class="timers-form flex items-end gap-1.5">
      <label class="flex flex-col text-xs font-medium flex-1">
        min
        <input class="timers-min border-2 border-secondary px-2 py-1 w-full" type="number" min="0" max="600" value="0" inputmode="numeric" />
      </label>
      <label class="flex flex-col text-xs font-medium flex-1">
        seg
        <input class="timers-sec border-2 border-secondary px-2 py-1 w-full" type="number" min="0" max="59" value="0" inputmode="numeric" />
      </label>
      <button type="submit" class="timers-add cursor-pointer border-2 border-secondary bg-secondary text-white px-3 py-2 font-bold flex items-center" aria-label="Crear temporizador"><Icon name="lucide:plus" class="w-4 h-4" /></button>
    </form>
  </div>
</div>

<script>
  import { icons } from "@lib/icons";

  type Timer = {
    endAt: number;
    remaining: number;
    paused: boolean;
    done: boolean;
    li: HTMLLIElement;
    alarm?: number;
  };

  function setupTimers() {
    const root = document.querySelector<HTMLElement>(".timers-root");
    if (!root || root.dataset.bound === "1") return;
    root.dataset.bound = "1";

    const fab = root.querySelector<HTMLButtonElement>(".timers-fab")!;
    const badge = root.querySelector<HTMLElement>(".timers-badge")!;
    const panel = root.querySelector<HTMLElement>(".timers-panel")!;
    const closeBtn = root.querySelector<HTMLButtonElement>(".timers-close")!;
    const list = root.querySelector<HTMLUListElement>(".timers-list")!;
    const empty = root.querySelector<HTMLElement>(".timers-empty")!;
    const form = root.querySelector<HTMLFormElement>(".timers-form")!;
    const minInput = root.querySelector<HTMLInputElement>(".timers-min")!;
    const secInput = root.querySelector<HTMLInputElement>(".timers-sec")!;
    const pendingRow = root.querySelector<HTMLElement>(".timers-pending")!;
    const pendingTime = root.querySelector<HTMLElement>(".timers-pending-time")!;
    const pendingStart = root.querySelector<HTMLButtonElement>(".timers-pending-start")!;

    const timers: Timer[] = [];
    let audioCtx: AudioContext | null = null;

    const unlockAudio = () => {
      try {
        audioCtx = audioCtx || new (window.AudioContext || (window as any).webkitAudioContext)();
        if (audioCtx.state === "suspended") audioCtx.resume();
      } catch {}
    };

    const beep = () => {
      if (!audioCtx) return;
      const o = audioCtx.createOscillator();
      const g = audioCtx.createGain();
      o.connect(g); g.connect(audioCtx.destination);
      o.type = "sine"; o.frequency.value = 880;
      const t = audioCtx.currentTime;
      g.gain.setValueAtTime(0.0001, t);
      g.gain.exponentialRampToValueAtTime(0.3, t + 0.01);
      g.gain.exponentialRampToValueAtTime(0.0001, t + 0.4);
      o.start(t); o.stop(t + 0.4);
    };

    // H:MM:SS cuando hay horas, MM:SS en otro caso.
    const fmt = (ms: number) => {
      const s = Math.max(0, Math.ceil(ms / 1000));
      const h = Math.floor(s / 3600);
      const m = Math.floor((s % 3600) / 60);
      const sec = s % 60;
      const pad = (n: number) => String(n).padStart(2, "0");
      return h > 0 ? `${h}:${pad(m)}:${pad(sec)}` : `${pad(m)}:${pad(sec)}`;
    };

    const updateBadge = () => {
      const active = timers.length;
      badge.textContent = String(active);
      badge.classList.toggle("hidden", active === 0);
      badge.classList.toggle("flex", active > 0);
    };

    const renderTimer = (timer: Timer) => {
      const display = timer.li.querySelector<HTMLElement>(".timer-time")!;
      const pause = timer.li.querySelector<HTMLButtonElement>(".timer-pause")!;
      display.textContent = timer.done ? "¡Listo!" : fmt(timer.remaining);
      pause.innerHTML = timer.paused ? icons.play : icons.pause;
      pause.hidden = timer.done;
    };

    const removeTimer = (timer: Timer) => {
      if (timer.alarm) clearInterval(timer.alarm);
      timer.li.remove();
      const i = timers.indexOf(timer);
      if (i >= 0) timers.splice(i, 1);
      empty.hidden = timers.length > 0;
      updateBadge();
    };

    const ring = (timer: Timer) => {
      timer.done = true;
      timer.li.classList.add("timer-done");
      renderTimer(timer);
      let beeps = 0;
      timer.alarm = window.setInterval(() => {
        beep();
        if (navigator.vibrate) navigator.vibrate([300, 150, 300]);
        if (++beeps >= 8) { clearInterval(timer.alarm); timer.alarm = undefined; }
      }, 800);
      panel.hidden = false; // mostrar el panel al sonar
    };

    const addTimer = (seconds: number) => {
      if (seconds <= 0) return;
      unlockAudio();
      const li = document.createElement("li");
      li.className = "timer-item flex items-center gap-2 border-2 border-secondary px-2 py-1";
      li.innerHTML = `
        <span class="timer-time font-bold tabular-nums text-lg flex-1"></span>
        <button type="button" class="timer-pause cursor-pointer" aria-label="Pausar/Reanudar"></button>
        <button type="button" class="timer-cancel cursor-pointer" aria-label="Quitar">${icons.x}</button>`;
      const timer: Timer = {
        endAt: Date.now() + seconds * 1000,
        remaining: seconds * 1000,
        paused: false,
        done: false,
        li,
      };
      li.querySelector(".timer-pause")!.addEventListener("click", (e) => {
        e.stopPropagation();
        if (timer.done) return;
        timer.paused = !timer.paused;
        if (!timer.paused) timer.endAt = Date.now() + timer.remaining;
        renderTimer(timer);
      });
      li.querySelector(".timer-cancel")!.addEventListener("click", (e) => {
        e.stopPropagation();
        removeTimer(timer);
      });
      // Cuando ha sonado, un toque en cualquier parte del timer lo descarta.
      li.addEventListener("click", () => { if (timer.done) removeTimer(timer); });

      timers.push(timer);
      list.append(li);
      empty.hidden = true;
      renderTimer(timer);
      updateBadge();
    };

    setInterval(() => {
      const now = Date.now();
      for (const timer of timers) {
        if (timer.paused || timer.done) continue;
        timer.remaining = timer.endAt - now;
        if (timer.remaining <= 0) { timer.remaining = 0; ring(timer); }
        else renderTimer(timer);
      }
    }, 250);

    // Cualquier preset suma su tiempo a un acumulador compartido. Tras una
    // breve pausa sin pulsar se crea el temporizador (como un microondas);
    // también se puede iniciar al momento con el botón "Iniciar".
    let pendingSeconds = 0;
    let pendingTimeout: number | undefined;
    const updatePending = () => {
      pendingTime.textContent = fmt(pendingSeconds * 1000);
      pendingRow.classList.toggle("hidden", pendingSeconds <= 0);
      pendingRow.classList.toggle("flex", pendingSeconds > 0);
    };
    const commitPending = () => {
      if (pendingTimeout) clearTimeout(pendingTimeout);
      pendingTimeout = undefined;
      if (pendingSeconds > 0) addTimer(pendingSeconds);
      pendingSeconds = 0;
      updatePending();
    };
    for (const btn of root.querySelectorAll<HTMLButtonElement>(".timers-add-min")) {
      btn.addEventListener("click", () => {
        unlockAudio();
        pendingSeconds += Number(btn.dataset.min) * 60;
        updatePending();
        if (pendingTimeout) clearTimeout(pendingTimeout);
        pendingTimeout = window.setTimeout(commitPending, 1800);
      });
    }
    pendingStart.addEventListener("click", commitPending);

    fab.addEventListener("click", (e) => { e.stopPropagation(); unlockAudio(); panel.hidden = !panel.hidden; });
    closeBtn.addEventListener("click", () => { panel.hidden = true; });
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      addTimer(Number(minInput.value || 0) * 60 + Number(secInput.value || 0));
      minInput.value = "0"; secInput.value = "0";
    });

    // Tocar fuera del panel lo cierra.
    document.addEventListener("click", (e) => {
      if (!panel.hidden && !root.contains(e.target as Node)) panel.hidden = true;
    });

    // API para que otras partes (modo guiado, pasos) creen timers.
    (window as any).cookAddTimer = addTimer;
  }

  if (document.readyState !== "loading") setupTimers();
  else document.addEventListener("DOMContentLoaded", setupTimers);
  document.addEventListener("astro:page-load", setupTimers);
</script>
